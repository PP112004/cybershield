# Copy this file to .env and fill in real values. .env is gitignored.
#
# LLM provider for case-narrative generation. Optional: with no key the
# service falls back to deterministic templates and still works.
#
# LLM_PROVIDER is auto-detected from whichever key is set; set it explicitly
# only to force a provider or to disable LLM calls (deepseek | gemini | none).

# LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# DEEPSEEK_MODEL=deepseek-chat

# GEMINI_API_KEY=your-gemini-key-here
